
#
ROOTDIR				:= $(realpath .)
BINDIR				:= $(ROOTDIR)/_Data

###########################################################################

all: build_all

###########################################################################

build_all: \
	build_dir_tree \
	build_stack \
	build_printer \
	build_archive
	@echo "Done"

###########################################################################

build_dir_tree:
	rm -rf $(BINDIR)
	mkdir -p $(BINDIR)/usb3/Devs
	mkdir -p $(BINDIR)/usb3/Libs/USB3
	mkdir -p $(BINDIR)/usb3/Kickstart

###########################################################################

build_stack:
	@echo "Building Stack"
	cd $(ROOTDIR) && \
	make -f makefile clean && \
	make -f makefile && \
	make -f makefile strip && \
	cp bin/usb3.device $(BINDIR)/usb3/Kickstart
	@echo "Stack done"

###########################################################################

build_printer:
	@echo "Building Printer Driver"
	cd $(ROOTDIR)/Drivers/Printer && \
	make -f makefile USBTYPE=USB3 clean && \
	make -f makefile USBTYPE=USB3 && \
	make -f makefile USBTYPE=USB3 strip && \
	cp bin/usb3_printer.device $(BINDIR)/usb3/Devs
	@echo "Printer done"

###########################################################################

build_archive:
	@echo "Building Archive"
	@rm usb3.lha
	lha a usb3.lha $(BINDIR)/usb3
	@echo "Building done"

###########################################################################
